# Зависимости — устанавливаются внутри контейнера
/vendor
/node_modules

# Скомпилированные ассеты — собираются node-сервисом внутри Docker
/public/build
/public/hot

# Кэш шаблонов и логи — генерируются в контейнере
/storage/framework/views
/storage/logs/*.log

# Секреты — не должны попасть в образ
/.env

# Git-история — не нужна в контейнере
.git
.gitignore
